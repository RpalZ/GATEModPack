			}]
			x: -2.0d
			y: 2.5d
		}
		{
			dependencies: ["023B9345FAF2ABCC"]
			description: [
				"&6&oThe first thing that answers the dragon's fall is a guardian born of harsher ruin. It moves like a fortress with a heartbeat, and the End seems to recoil wherever it walks.&r&r"
				""
				"&4&o\"The End is still hiding its teeth.\"&r&r"
			]
			icon: "minecraft:shulker_box"
			id: "69712D8B4DFADE6C"
			rewards: [
				{
					exclude_from_claim_all: true
