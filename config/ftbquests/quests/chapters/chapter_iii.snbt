		{
			dependencies: ["5E66F197D6DA73F9"]
			description: [
				"&6&oThe dragon falls, but victory here feels incomplete. The End does not empty so easily, and its shadows still cling to the broken islands like a warning left unfinished. Even so, its hoard should spill open for those who survive the fight.&r&r"
				""
				"&4&o\"A slain dragon leaves behind more than bones if the hunt was worthy.\"&r&r"
			]
			icon: "minecraft:dragon_head"
			id: "023B9345FAF2ABCC"
