		}
		{
			dependencies: ["69712D8B4DFADE6C"]
			description: [
				"&6&oAmong the broken stars, a second figure appears wearing the shape of a familiar enemy, but not its soul. It moves too smoothly, too deliberately, like a reflection that learned how to hunt. It is but a puppet, woven from the miasma itself to stall your final descent.&r&r"
				""
				"&4&o\"Something is wearing our fear like a mask, desperate to guard its master.\"&r&r"
			]
			icon: "darkdoppelganger:doppelganger_ring"
			id: "7439F90F2ECE4041"
