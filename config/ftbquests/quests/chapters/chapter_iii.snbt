		{
			dependencies: ["7978A173146F39D6"]
			description: [
				"&6&oThe final path begins where the worlds thin out. The Gate has been reached, but the silence beyond it feels less like peace and more like something holding its breath.&r&r"
				""
				"&4&o\"If the trail ends here, then whatever waits beyond has been waiting for us.\"&r&r"
			]
			id: "61CA71F2A65B0171"
			tasks: [{
				id: "5DB44384BA783EB9"
				title: "Final Step"
				type: "checkmark"
			}]
			x: 0.5d
			y: -0.5d
		}
		{
			dependencies: ["61CA71F2A65B0171"]
			description: [
				"&6&oAt last, the End itself opens before you. The air is still, the ground is silent, and the sky is wrong, as if the world has been stripped down to its bones.&r&r"
				""
				"&4&o\"There is no turning back now.\"&r&r"
			]
