	quest_links: [ ]
	quests: [
		{
			description: [
				"&o&o&7For generations, the world was trapped in the Great War, a cycle of rage that left the overworld full of broken kingdoms and buried grudges. Then, at the height of that conflict, an unnatural miasma began to spread across the land.&r"
				""
				"&o&7Entire cities vanished in an instant, swallowed by a cold emptiness that left nothing behind. Forced to face a threat they could not understand, the warring races laid down their pride and signed the Pact of the Gate, uniting their magic and technology into one desperate defense. The Great War ended, but a darker battle began against the shadow that now threatens to erase existence itself.&r&r&r"
				""
				"&4&o\"If the war ended, why does the world still feel like it is dying?\"&r&r"
			]
			id: "46B96E1D0D8B7BCA"
			tasks: [{
				id: "11A022A00DBEAE16"
				title: "The Great War"
				type: "checkmark"
			}]
			x: -0.5d
			y: -0.5d
		}
		{
			dependencies: ["46B96E1D0D8B7BCA"]
			description: [
				"&6&oIf we are to stand against what waits beyond the Gate, strength cannot be borrowed forever. Each warrior must prove they can carry their own weight so the whole can endure as one. Hunt down the enemies of the Pact and claim the first key to the source of this corruption.&r&r"
				""
				"&4&o\"Begin with the broken remnants of the old war. Power is forged in the first victory.\"&r&r"
			]
			id: "79F4974E23BC93AA"
			rewards: [{
				auto: "enabled"
				id: "54817231C4FAF88E"
				item: {
					Count: 1
					id: "endrem:corrupted_eye"
					tag: {
						Damage: 0
					}
				}
				type: "item"
			}]
			subtitle: "Prove Yourself."
			tasks: [{
				entity: "minecraft:pillager"
				icon: {
					Count: 1
					id: "minecraft:stone_sword"
					tag: {
						Damage: 0
					}
				}
				id: "6083DDE285B4E762"
				title: "Kill Pillagers"
				type: "kill"
				value: 15L
			}]
			title: "First Quest"
			x: -0.5d
			y: 1.5d
		}
		{
			dependencies: ["79F4974E23BC93AA"]
			description: [
				"&o&6The pillagers fell, and among their spoils was a corrupted eye tied to the same force that devoured the old cities. Even a small relic like this may reveal where the miasma began.&r&r"
				""
				"&4&o\"Every fragment matters when the enemy leaves nothing behind.\"&r&r"
			]
			id: "6983BBC406DF52C0"
			rewards: [{
				id: "061AD04A9B69FE3E"
				type: "xp"
				xp: 500
			}]
			tasks: [{
