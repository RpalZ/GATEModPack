			x: 2.0d
			y: 1.5d
		}
		{
			dependencies: ["6983BBC406DF52C0"]
			description: [
				"&6&oAs the miasma spreads across the horizons, even the savannah is not spared. A sacred bird once blessed by divinity has been twisted into a blasphemous tyrant, gathering an army beneath its corrupted wings.&r&r"
				""
				"&4&o\"If the wild has fallen to corruption, then the one who defiles it must be brought down.\"&r&r"
			]
			id: "083CFC179D001044"
