		}
		{
			dependencies: ["7E2ECADBF5753E0B"]
			description: [
				"&6&oThe seas answered next. High above the water, an ancient acropolis stands over the coastline, and within its broken halls something vast and ancient has stirred with the same corruption that touched the land. Its defeat would leave the old ruins open to salvage.&r&r"
				""
				"&4&o\"Even what floats above the sea can still be claimed by the deep.\"&r&r"
			]
			icon: "cataclysm:storm_eye"
			id: "5FB3D665CD41869F"
