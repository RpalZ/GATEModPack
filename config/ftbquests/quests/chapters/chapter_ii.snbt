	quests: [
		{
			description: [
				"&6&oThe Wither fell, but the miasma did not. Instead, it spread farther, seeping into ruins, depths, and distant realms. Whatever is feeding it now hides behind many faces, and every trail leads deeper.&r"
				"&r&r"
				""
				"&4&o\"The source has changed its shape, but not its hunger.\"&r&r"
			]
			id: "5DBF17299A0DE31E"
			rewards: [{
				id: "5D86CC3DCFD90267"
				type: "xp"
				xp: 100
			}]
			tasks: [{
